# --- General ---
ENVIRONMENT=local
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Storage backend: local | adls ---
STORAGE_BACKEND=local

# --- ADLS Gen2 (only when STORAGE_BACKEND=adls) ---
# Option A: connection string
# ADLS_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# Option B: account name + managed identity (recommended on Azure)
# ADLS_ACCOUNT_NAME=mystorageaccount
ADLS_FILESYSTEM=parse-studio
ADLS_ORIGINALS_PREFIX=originals
ADLS_JSON_PREFIX=parsed

# --- Docling ---
DOCLING_DO_OCR=true
DOCLING_DO_TABLE_STRUCTURE=true
