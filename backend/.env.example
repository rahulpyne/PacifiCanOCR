# --- General ---
ENVIRONMENT=local
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Storage backend: local | adls ---
STORAGE_BACKEND=local

# --- ADLS Gen2 (only when STORAGE_BACKEND=adls) ---
# Auth — choose ONE:
#   Option A: connection string (simplest; from Storage account → Access keys)
# ADLS_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
#   Option B: account name + managed identity (recommended on Azure App Service)
# ADLS_ACCOUNT_NAME=pacificanocrdocuments

# Two separate ADLS containers (filesystems):
ADLS_ORIGINALS_FILESYSTEM=originalfiles     # original uploaded files
ADLS_JSON_FILESYSTEM=parsedjsons            # final downloadable JSON + records

# --- Docling ---
DOCLING_DO_OCR=true
DOCLING_DO_TABLE_STRUCTURE=true
# OCR strategy: auto (skip OCR when the PDF already has a text layer) | on | off
DOCLING_OCR_MODE=auto
# Pre-downloaded model dir (set in the Docker image; leave unset locally).
# DOCLING_ARTIFACTS_PATH=/opt/docling-models
